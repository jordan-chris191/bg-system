  attachments     WorkOrderAttachment[]
  maintenances    Maintenance[]
  documents       DocumentLink[]

  @@index([assetId])
  @@index([requestedBy])
  @@index([assignedTo])
  @@index([approvedBy])
  @@index([workOrderStatusId])
  @@index([workOrderPriorityId])
  @@index([createdAt])
  @@index([completedAt])
  @@index([deletedAt])
  @@map("work_orders")
}

