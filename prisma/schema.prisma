// CONSUMABLE INVENTORY MODULE
// ─────────────────────────────────────────────────────────────

model ConsumableCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  code        String   @unique @db.VarChar(50)
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")
  deletedAt   DateTime? @db.Timestamptz(6) @map("deleted_at")

  consumables Consumable[]

  @@index([isActive])
  @@map("consumable_categories")
}

model Consumable {
  id                String   @id @default(uuid()) @db.Uuid
  consumableCategoryId String @map("consumable_category_id") @db.Uuid
  name              String   @db.VarChar(200)
  code              String   @unique @db.VarChar(50)
  description       String?  @db.Text
  unitOfMeasure     String   @map("unit_of_measure") @db.VarChar(50)
  currentStock      Decimal  @default(0) @map("current_stock") @db.Decimal(12, 2)
  minimumStock      Decimal  @map("minimum_stock") @db.Decimal(12, 2)
  maximumStock      Decimal? @map("maximum_stock") @db.Decimal(12, 2)
  reorderLevel      Decimal  @map("reorder_level") @db.Decimal(12, 2)
  supplier          String?  @db.VarChar(200)
  supplierContact   String?  @map("supplier_contact") @db.VarChar(255)
  unitCost          Decimal? @map("unit_cost") @db.Decimal(12, 2)
  location          String?  @db.VarChar(200)
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt         DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")
  deletedAt         DateTime? @db.Timestamptz(6) @map("deleted_at")

  consumableCategory ConsumableCategory @relation(fields: [consumableCategoryId], references: [id], onDelete: Restrict)
  stockTransactions  StockTransaction[]

  @@index([consumableCategoryId])
  @@index([isActive])
  @@index([currentStock])
  @@index([deletedAt])
  @@map("consumables")
}

model StockTransaction {
  id              String               @id @default(uuid()) @db.Uuid
  consumableId    String               @map("consumable_id") @db.Uuid
  transactionType StockTransactionType @map("transaction_type")
  quantity        Decimal              @db.Decimal(12, 2)
  unitCost        Decimal?             @map("unit_cost") @db.Decimal(12, 2)
  totalCost       Decimal?             @map("total_cost") @db.Decimal(12, 2)
  referenceNumber String?              @map("reference_number") @db.VarChar(100)
  reason          String?              @db.Text
  performedBy     String               @map("performed_by") @db.Uuid
  performedAt     DateTime             @map("performed_at") @db.Timestamptz(6)
  stockBefore     Decimal              @map("stock_before") @db.Decimal(12, 2)
  stockAfter      Decimal              @map("stock_after") @db.Decimal(12, 2)
  workOrderId     String?              @map("work_order_id") @db.Uuid
  maintenanceId   String?              @map("maintenance_id") @db.Uuid
  createdAt       DateTime             @default(now()) @db.Timestamptz(6) @map("created_at")

  consumable Consumable @relation(fields: [consumableId], references: [id], onDelete: Restrict)
  user       User       @relation(fields: [performedBy], references: [id], onDelete: Restrict)

  @@index([consumableId])
  @@index([performedBy])
  @@index([transactionType])
  @@index([performedAt])
  @@index([workOrderId])
  @@index([maintenanceId])
  @@map("stock_transactions")
}

// ─────────────────────────────────────────────────────────────
// DOCUMENT MODULE
// ─────────────────────────────────────────────────────────────

model Document {
  id          String     @id @default(uuid()) @db.Uuid
  fileName    String     @map("file_name") @db.VarChar(255)
  filePath    String     @map("file_path") @db.Text
  fileSize    Int        @map("file_size")
  mimeType    String     @map("mime_type") @db.VarChar(100)
  documentType DocumentType @map("document_type")
  description String?    @db.Text
  uploadedBy  String     @map("uploaded_by") @db.Uuid
  uploadedAt  DateTime   @map("uploaded_at") @db.Timestamptz(6)
  checksum    String     @db.VarChar(64)
  createdAt   DateTime   @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime   @updatedAt @db.Timestamptz(6) @map("updated_at")
  deletedAt   DateTime?  @db.Timestamptz(6) @map("deleted_at")

  documentLinks DocumentLink[]

  @@index([uploadedBy])
  @@index([documentType])
  @@index([uploadedAt])
  @@index([deletedAt])
  @@map("documents")
}

model DocumentLink {
  id           String   @id @default(uuid()) @db.Uuid
  documentId   String   @map("document_id") @db.Uuid
  entityType   String   @map("entity_type") @db.VarChar(50)
  entityId     String   @map("entity_id") @db.Uuid
  createdAt    DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Restrict)

  asset           Asset?           @relation(fields: [entityId], references: [id], onDelete: Restrict, map: "document_link_asset_fk")
  maintenance     Maintenance?     @relation(fields: [entityId], references: [id], onDelete: Restrict, map: "document_link_maintenance_fk")
  assetTransfer   AssetTransfer?   @relation(fields: [entityId], references: [id], onDelete: Restrict, map: "document_link_transfer_fk")
  assetInspection AssetInspection? @relation(fields: [entityId], references: [id], onDelete: Restrict, map: "document_link_inspection_fk")
  workOrder       WorkOrder?       @relation(fields: [entityId], references: [id], onDelete: Restrict, map: "document_link_work_order_fk")

  @@index([documentId])
  @@index([entityType])
  @@index([entityId])
  @@unique([documentId, entityType, entityId])
  @@map("document_links")
}

// ─────────────────────────────────────────────────────────────
// NOTIFICATION MODULE
// ─────────────────────────────────────────────────────────────

model Notification {
  id          String           @id @default(uuid()) @db.Uuid
  recipientId String           @map("recipient_id") @db.Uuid
  senderId    String?          @map("sender_id") @db.Uuid
  type        NotificationType
  title       String           @db.VarChar(300)
  message     String           @db.Text
  entityType  String?          @map("entity_type") @db.VarChar(50)
  entityId    String?          @map("entity_id") @db.Uuid
  isRead      Boolean          @default(false) @map("is_read")
  readAt      DateTime?        @map("read_at") @db.Timestamptz(6)
  actionUrl   String?          @map("action_url") @db.Text
  createdAt   DateTime         @default(now()) @db.Timestamptz(6) @map("created_at")

  recipient User  @relation(fields: [recipientId], references: [id], onDelete: Restrict)

  @@index([recipientId])
  @@index([senderId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@map("notifications")
}

model NotificationPreference {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  notificationType NotificationType @map("notification_type")
  emailEnabled    Boolean          @default(true) @map("email_enabled")
  inAppEnabled    Boolean          @default(true) @map("in_app_enabled")
  pushEnabled     Boolean          @default(false) @map("push_enabled")
  createdAt       DateTime         @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt       DateTime         @updatedAt @db.Timestamptz(6) @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([userId, notificationType])
  @@index([userId])
  @@map("notification_preferences")
}

// ─────────────────────────────────────────────────────────────
// AUDIT MODULE
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id String @id @default(uuid()) @db.Uuid

  /// What happened
  action AuditAction

  /// Business entity affected
  entityType EntityType @map("entity_type")
  entityId   String     @map("entity_id") @db.Uuid

  /// Human-readable snapshot
  entityName String? @map("entity_name") @db.VarChar(255)

  /// Detailed description for logs/UI
  description String? @db.Text

  /// Before and after values
  oldValues Json? @map("old_values") @db.JsonB
  newValues Json? @map("new_values") @db.JsonB

  /// Additional context
  metadata Json? @db.JsonB

  /// Who performed the action
  performedBy String? @map("performed_by") @db.Uuid
  user        User?   @relation(fields: [performedBy], references: [id], onDelete: Restrict)

  /// Request information
  ipAddress String? @map("ip_address") @db.VarChar(45)
  userAgent String? @map("user_agent") @db.Text

  /// Timestamp
  performedAt DateTime @default(now()) @map("performed_at") @db.Timestamptz(6)

  @@index([performedBy])
  @@index([entityType, entityId])
  @@index([action])
  @@index([performedAt])

  @@map("audit_logs")
}

