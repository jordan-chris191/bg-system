generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum StockTransactionType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
}

enum DocumentType {
  IMAGE
  PDF
  WORD
  EXCEL
  OTHER
}

enum NotificationType {
  NEW_WORK_ORDER
  MAINTENANCE_DUE
  LOW_INVENTORY
  ASSET_TRANSFER
  INSPECTION_DUE
  SYSTEM_ALERT
  WORK_ORDER_ASSIGNED
  WORK_ORDER_COMPLETED
  MAINTENANCE_COMPLETED
  ASSET_ASSIGNED
  ASSET_TRANSFER_APPROVED
  ASSET_TRANSFER_REJECTED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  ASSIGN
  TRANSFER
  COMPLETE
  CANCEL
  RESTORE
}

enum EntityType {
  ASSET
  ASSET_TRANSFER
  ASSET_ASSIGNMENT
  WORK_ORDER
  MAINTENANCE
  CONSUMABLE
  STOCK_TRANSACTION
  BUILDING
  FLOOR
  ROOM
  USER
  ROLE
  DOCUMENT
  NOTIFICATION
  SYSTEM_SETTING
}

// ─────────────────────────────────────────────────────────────
// LOOKUP TABLES (converted from enums)
// ─────────────────────────────────────────────────────────────

model TransferStatus {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  color       String?  @db.VarChar(20)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")

  assetTransfers   AssetTransfer[]
  transferApprovals TransferApproval[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("transfer_statuses")
}

model MaintenanceStatus {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  color       String?  @db.VarChar(20)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")

  maintenances Maintenance[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("maintenance_statuses")
}

model WorkOrderStatus {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  color       String?  @db.VarChar(20)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")

  workOrders      WorkOrder[]
  statusHistories WorkOrderStatusHistory[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("work_order_statuses")
}

model WorkOrderPriority {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  color       String?  @db.VarChar(20)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")

  workOrders WorkOrder[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("work_order_priorities")
}

// ─────────────────────────────────────────────────────────────
// AUTHENTICATION MODULE
// ─────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")
  deletedAt   DateTime? @db.Timestamptz(6) @map("deleted_at")

  rolePermissions RolePermission[]
  users           User[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  code        String   @unique @db.VarChar(100)
  description String?  @db.Text
  module      String   @db.VarChar(100)
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")
  deletedAt   DateTime? @db.Timestamptz(6) @map("deleted_at")

  rolePermissions RolePermission[]

  @@index([module])
  @@index([code])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model User {
  id                 String     @id @default(uuid()) @db.Uuid
  employeeId         String     @unique @map("employee_id") @db.VarChar(50)
  username           String     @unique @db.VarChar(50)
  email              String     @unique @db.VarChar(255)
  passwordHash       String     @map("password_hash") @db.Text
  firstName          String     @map("first_name") @db.VarChar(100)
  middleName         String?    @map("middle_name") @db.VarChar(100)
  lastName           String     @map("last_name") @db.VarChar(100)
  position           String?    @db.VarChar(150)
  department         String?    @db.VarChar(150)
  roleId             String     @map("role_id") @db.Uuid
  isActive           Boolean    @default(true) @map("is_active")
  mustChangePassword Boolean    @default(true) @map("must_change_password")
  lastLoginAt        DateTime?  @map("last_login_at") @db.Timestamptz(6)
  twoFactorSecret    String?    @map("two_factor_secret") @db.VarChar(255)
  twoFactorEnabled   Boolean    @default(false) @map("two_factor_enabled")
  createdAt          DateTime   @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt          DateTime   @updatedAt @db.Timestamptz(6) @map("updated_at")
  deletedAt          DateTime?  @db.Timestamptz(6) @map("deleted_at")

  role               Role                @relation(fields: [roleId], references: [id], onDelete: Restrict)
  passwordResetTokens PasswordResetToken[]
  refreshTokens      RefreshToken[]
  loginAttempts      LoginAttempt[]
  sessions           Session[]
  workOrdersRequested WorkOrder[]        @relation("WorkOrderRequestedBy")
  workOrdersApproved  WorkOrder[]        @relation("WorkOrderApprovedBy")
  workOrdersAssigned  WorkOrder[]        @relation("WorkOrderAssignedTo")
  maintenanceRecords  Maintenance[]      @relation("MaintenanceTechnician")
  assetAssignments    AssetAssignment[]
  assetsAsCustodian   Asset[]            @relation("AssetCurrentCustodian")
  assetTransfersFrom  AssetTransfer[]    @relation("AssetTransferFrom")
  assetTransfersTo    AssetTransfer[]    @relation("AssetTransferTo")
  transferApprovals   TransferApproval[]
  assetInspections    AssetInspection[]
  stockTransactions   StockTransaction[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  notificationPreferences NotificationPreference[]
  announcements       Announcement[]

  @@index([roleId])
  @@index([isActive])
  @@index([createdAt])
  @@index([lastLoginAt])
  @@index([deletedAt])
  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model LoginAttempt {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  username  String   @db.VarChar(50)
  ipAddress String   @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.Text
  success   Boolean
  failureReason String? @map("failure_reason") @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([username])
  @@index([ipAddress])
  @@index([createdAt])
  @@index([success])
  @@map("login_attempts")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.Text
  lastActiveAt DateTime? @map("last_active_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

// ─────────────────────────────────────────────────────────────
// ORGANIZATION STRUCTURE
// ─────────────────────────────────────────────────────────────

model Campus {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  code        String   @unique @db.VarChar(20)
  address     String?  @db.Text
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")
  deletedAt   DateTime? @db.Timestamptz(6) @map("deleted_at")

  colleges College[]

  @@index([code])
  @@index([isActive])
  @@map("campuses")
}

model College {
  id          String   @id @default(uuid()) @db.Uuid
  campusId    String   @map("campus_id") @db.Uuid
  name        String   @db.VarChar(200)
  code        String   @db.VarChar(20)
  deanName    String?  @map("dean_name") @db.VarChar(200)
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")
  deletedAt   DateTime? @db.Timestamptz(6) @map("deleted_at")

  campus   Campus    @relation(fields: [campusId], references: [id], onDelete: Restrict)
  buildings Building[]

  @@unique([campusId, code])
  @@index([campusId])
  @@index([isActive])
  @@map("colleges")
}

model Building {
  id          String   @id @default(uuid()) @db.Uuid
  collegeId   String   @map("college_id") @db.Uuid
  name        String   @db.VarChar(200)
  code        String   @db.VarChar(20)
  description String?  @db.Text
  yearBuilt   Int?     @map("year_built")
  totalFloors Int      @default(1) @map("total_floors")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")
  deletedAt   DateTime? @db.Timestamptz(6) @map("deleted_at")

  college College @relation(fields: [collegeId], references: [id], onDelete: Restrict)
  floors  Floor[]

  @@unique([collegeId, code])
  @@index([collegeId])
  @@index([isActive])
  @@map("buildings")
}

model Floor {
  id          String   @id @default(uuid()) @db.Uuid
  buildingId  String   @map("building_id") @db.Uuid
  floorNumber Int      @map("floor_number")
  name        String?  @db.VarChar(100)
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")
  deletedAt   DateTime? @db.Timestamptz(6) @map("deleted_at")

  building Building @relation(fields: [buildingId], references: [id], onDelete: Restrict)
  rooms    Room[]

  @@unique([buildingId, floorNumber])
  @@index([buildingId])
  @@index([isActive])
  @@map("floors")
}

model Room {
  id          String   @id @default(uuid()) @db.Uuid
  floorId     String   @map("floor_id") @db.Uuid
  roomNumber  String   @map("room_number") @db.VarChar(50)
  name        String?  @db.VarChar(100)
  roomType    String?  @map("room_type") @db.VarChar(50)
  capacity    Int?
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")
  deletedAt   DateTime? @db.Timestamptz(6) @map("deleted_at")

  floor         Floor           @relation(fields: [floorId], references: [id], onDelete: Restrict)
  assets        Asset[]
  assetTransfersFrom AssetTransfer[] @relation("AssetTransferFromRoom")
  assetTransfersTo   AssetTransfer[] @relation("AssetTransferToRoom")

  @@unique([floorId, roomNumber])
  @@index([floorId])
  @@index([isActive])
  @@map("rooms")
}

// ─────────────────────────────────────────────────────────────
// ASSET MANAGEMENT MODULE
// ─────────────────────────────────────────────────────────────

model AssetCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  code        String   @unique @db.VarChar(50)
  description String?  @db.Text
  parentId    String?  @map("parent_id") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")
  deletedAt   DateTime? @db.Timestamptz(6) @map("deleted_at")

  parent   AssetCategory?  @relation("AssetCategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children AssetCategory[] @relation("AssetCategoryHierarchy")
  assets   Asset[]

  @@index([parentId])
  @@index([isActive])
  @@map("asset_categories")
}

model Asset {
  id                  String    @id @default(uuid()) @db.Uuid

  propertyNumber      String    @unique @map("property_number") @db.VarChar(100)
  serialNumber        String?   @unique @map("serial_number") @db.VarChar(200)

  barcodeValue        String?   @unique @map("barcode_value") @db.VarChar(200)

  assetCategoryId     String    @map("asset_category_id") @db.Uuid

  assetStatusId       String    @map("asset_status_id") @db.Uuid
  assetConditionId    String    @map("asset_condition_id") @db.Uuid

  manufacturer        String?   @db.VarChar(200)
  brand               String?   @db.VarChar(200)
  model               String?   @db.VarChar(200)

  purchaseDate        DateTime? @map("purchase_date") @db.Timestamptz(6)
  purchaseCost        Decimal?  @map("purchase_cost") @db.Decimal(12, 2)

  usefulLife          Int?      @map("useful_life")

  warrantyExpiration  DateTime? @map("warranty_expiration") @db.Timestamptz(6)

  roomId              String?   @map("room_id") @db.Uuid

  currentCustodianId  String?   @map("current_custodian_id") @db.Uuid

  remarks             String?   @db.Text

  specifications      Json?     @db.JsonB

  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz(6)

  assetCategory AssetCategory @relation(fields: [assetCategoryId], references: [id], onDelete: Restrict)

  assetStatus AssetStatus @relation(fields: [assetStatusId], references: [id], onDelete: Restrict)

  assetCondition AssetCondition @relation(fields: [assetConditionId], references: [id], onDelete: Restrict)

  room Room? @relation(fields: [roomId], references: [id], onDelete: Restrict)

  currentCustodian User? @relation("AssetCurrentCustodian", fields: [currentCustodianId], references: [id], onDelete: Restrict)

  assignments       AssetAssignment[]
  transfers         AssetTransfer[]
  transferApprovals TransferApproval[]
  inspections       AssetInspection[]
  images            AssetImage[]
  histories         AssetHistory[]
  maintenances      Maintenance[]
  documents         DocumentLink[]
  workOrders        WorkOrder[]

  @@index([assetCategoryId])
  @@index([assetStatusId])
  @@index([assetConditionId])
  @@index([roomId])
  @@index([currentCustodianId])

  @@index([propertyNumber])
  @@index([serialNumber])
  @@index([barcodeValue])

  @@index([purchaseDate])
  @@index([createdAt])
  @@index([deletedAt])

  @@map("assets")
}

model AssetStatus {
  id          String   @id @default(uuid()) @db.Uuid

  name        String   @unique @db.VarChar(100)

  description String?  @db.Text

  color       String?  @db.VarChar(20)

  sortOrder   Int      @default(0)

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  assets Asset[]

  @@index([isActive])
  @@index([sortOrder])

  @@map("asset_statuses")
}

model AssetCondition {
  id          String   @id @default(uuid()) @db.Uuid

  name        String   @unique @db.VarChar(100)

  description String?  @db.Text

  color       String?  @db.VarChar(20)

  sortOrder   Int      @default(0)

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  assets Asset[]
  assetInspections AssetInspection[]

  @@index([isActive])
  @@index([sortOrder])

  @@map("asset_conditions")
}

model AssetAssignment {
  id          String   @id @default(uuid()) @db.Uuid
  assetId     String   @map("asset_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  assignedAt  DateTime @map("assigned_at") @db.Timestamptz(6)
  returnedAt  DateTime? @map("returned_at") @db.Timestamptz(6)
  assignedBy  String   @map("assigned_by") @db.Uuid
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Restrict)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([assetId])
  @@index([userId])
  @@index([assignedAt])
  @@index([returnedAt])
  @@map("asset_assignments")
}

model AssetTransfer {
  id              String         @id @default(uuid()) @db.Uuid
  assetId         String         @map("asset_id") @db.Uuid
  fromRoomId      String?        @map("from_room_id") @db.Uuid
  toRoomId        String         @map("to_room_id") @db.Uuid
  transferredBy   String         @map("transferred_by") @db.Uuid
  transferDate    DateTime       @map("transfer_date") @db.Timestamptz(6)
  transferStatusId String @map("transfer_status_id") @db.Uuid
  transferStatus  TransferStatus @relation(fields: [transferStatusId], references: [id], onDelete: Restrict)
  reason          String?        @db.Text
  approvedBy      String?        @map("approved_by") @db.Uuid
  approvedAt      DateTime?      @map("approved_at") @db.Timestamptz(6)
  rejectionReason String?        @map("rejection_reason") @db.Text
  completedAt     DateTime?      @map("completed_at") @db.Timestamptz(6)
  createdAt       DateTime       @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt       DateTime       @updatedAt @db.Timestamptz(6) @map("updated_at")

  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Restrict)
  fromRoom  Room?    @relation("AssetTransferFromRoom", fields: [fromRoomId], references: [id], onDelete: Restrict)
  toRoom    Room     @relation("AssetTransferToRoom", fields: [toRoomId], references: [id], onDelete: Restrict)
  transferBy User    @relation("AssetTransferFrom", fields: [transferredBy], references: [id], onDelete: Restrict)
  approver   User?   @relation("AssetTransferTo", fields: [approvedBy], references: [id], onDelete: Restrict)
  approvals  TransferApproval[]
  documents  DocumentLink[]
  histories  AssetHistory[]

  @@index([assetId])
  @@index([fromRoomId])
  @@index([toRoomId])
  @@index([transferredBy])
  @@index([approvedBy])
  @@index([transferStatusId])
  @@index([transferDate])
  @@map("asset_transfers")
}

model TransferApproval {
  id              String   @id @default(uuid()) @db.Uuid
  assetTransferId String   @map("asset_transfer_id") @db.Uuid
  assetId         String   @map("asset_id") @db.Uuid
  approvedBy      String   @map("approved_by") @db.Uuid
  transferStatusId String  @map("transfer_status_id") @db.Uuid
  notes           String?  @db.Text
  approvedAt      DateTime @map("approved_at") @db.Timestamptz(6)
  createdAt       DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  assetTransfer AssetTransfer @relation(fields: [assetTransferId], references: [id], onDelete: Restrict)
  asset         Asset         @relation(fields: [assetId], references: [id], onDelete: Restrict)
  approver      User          @relation(fields: [approvedBy], references: [id], onDelete: Restrict)
  transferStatus TransferStatus @relation(fields: [transferStatusId], references: [id], onDelete: Restrict)

  @@index([assetTransferId])
  @@index([assetId])
  @@index([approvedBy])
  @@index([transferStatusId])
  @@map("transfer_approvals")
}

model AssetInspection {
  id              String   @id @default(uuid()) @db.Uuid
  assetId         String   @map("asset_id") @db.Uuid
  inspectedBy     String   @map("inspected_by") @db.Uuid
  inspectionDate  DateTime @map("inspection_date") @db.Timestamptz(6)
  assetConditionId String  @map("asset_condition_id") @db.Uuid
  findings        String?  @db.Text
  recommendations String?  @db.Text
  nextInspectionDate DateTime? @map("next_inspection_date") @db.Timestamptz(6)
  isSatisfactory  Boolean  @default(true) @map("is_satisfactory")
