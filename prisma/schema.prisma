// ─────────────────────────────────────────────────────────────
// MAINTENANCE MODULE
// ─────────────────────────────────────────────────────────────

model MaintenanceType {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  code        String   @unique @db.VarChar(50)
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt   DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")
  deletedAt   DateTime? @db.Timestamptz(6) @map("deleted_at")

  maintenances Maintenance[]
  schedules    MaintenanceSchedule[]

  @@index([isActive])
  @@map("maintenance_types")
}

model Maintenance {
  id              String           @id @default(uuid()) @db.Uuid
  maintenanceNumber String         @unique @map("maintenance_number") @db.VarChar(50)
  assetId         String           @map("asset_id") @db.Uuid
  workOrderId     String?          @map("work_order_id") @db.Uuid
  maintenanceTypeId String         @map("maintenance_type_id") @db.Uuid
  maintenanceStatusId String       @map("maintenance_status_id") @db.Uuid
  description     String           @db.Text
  cost            Decimal?         @db.Decimal(12, 2)
  technicianId    String?          @map("technician_id") @db.Uuid
  datePerformed   DateTime?        @map("date_performed") @db.Timestamptz(6)
  dateScheduled   DateTime         @map("date_scheduled") @db.Timestamptz(6)
  dateCompleted   DateTime?        @map("date_completed") @db.Timestamptz(6)
  findings        String?          @db.Text
  recommendations String?          @db.Text
  partsUsed       String?          @map("parts_used") @db.Text
  downtimeHours   Decimal?         @map("downtime_hours") @db.Decimal(8, 2)
  createdAt       DateTime         @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt       DateTime         @updatedAt @db.Timestamptz(6) @map("updated_at")
  deletedAt       DateTime?        @db.Timestamptz(6) @map("deleted_at")

  asset         Asset               @relation(fields: [assetId], references: [id], onDelete: Restrict)
  workOrder     WorkOrder?          @relation(fields: [workOrderId], references: [id], onDelete: Restrict)
  maintenanceType MaintenanceType   @relation(fields: [maintenanceTypeId], references: [id], onDelete: Restrict)
  maintenanceStatus MaintenanceStatus @relation(fields: [maintenanceStatusId], references: [id], onDelete: Restrict)
  technician    User?               @relation("MaintenanceTechnician", fields: [technicianId], references: [id], onDelete: Restrict)
  attachments   MaintenanceAttachment[]
  documents     DocumentLink[]

  @@index([assetId])
  @@index([workOrderId])
  @@index([maintenanceTypeId])
  @@index([maintenanceStatusId])
  @@index([technicianId])
  @@index([dateScheduled])
  @@index([dateCompleted])
  @@index([deletedAt])
  @@map("maintenances")
}

model MaintenanceSchedule {
  id                String        @id @default(uuid()) @db.Uuid
  assetId           String        @map("asset_id") @db.Uuid
  maintenanceTypeId String        @map("maintenance_type_id") @db.Uuid
  frequencyDays     Int           @map("frequency_days")
  lastPerformedDate DateTime?     @map("last_performed_date") @db.Timestamptz(6)
  nextDueDate       DateTime      @map("next_due_date") @db.Timestamptz(6)
  isActive          Boolean       @default(true) @map("is_active")
  notes             String?       @db.Text
  createdAt         DateTime      @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt         DateTime      @updatedAt @db.Timestamptz(6) @map("updated_at")

  maintenanceType MaintenanceType @relation(fields: [maintenanceTypeId], references: [id], onDelete: Restrict)

  @@index([assetId])
  @@index([maintenanceTypeId])
  @@index([nextDueDate])
  @@index([isActive])
  @@map("maintenance_schedules")
}

model MaintenanceAttachment {
  id            String   @id @default(uuid()) @db.Uuid
  maintenanceId String   @map("maintenance_id") @db.Uuid
  fileName      String   @map("file_name") @db.VarChar(255)
  filePath      String   @map("file_path") @db.Text
  fileSize      Int      @map("file_size")
  mimeType      String   @map("mime_type") @db.VarChar(100)
  description   String?  @db.Text
  createdAt     DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  maintenance Maintenance @relation(fields: [maintenanceId], references: [id], onDelete: Restrict)

  @@index([maintenanceId])
  @@map("maintenance_attachments")
}

