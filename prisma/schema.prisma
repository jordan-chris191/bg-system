model WorkOrder {
  id              String            @id @default(uuid()) @db.Uuid
  workOrderNumber String            @unique @map("work_order_number") @db.VarChar(50)
  title           String            @db.VarChar(300)
  description     String            @db.Text
  workOrderPriorityId String        @map("work_order_priority_id") @db.Uuid
  workOrderStatusId   String        @map("work_order_status_id") @db.Uuid
  assetId         String?           @map("asset_id") @db.Uuid
  roomId          String?           @map("room_id") @db.Uuid
  requestedBy     String            @map("requested_by") @db.Uuid
  assignedTo      String?           @map("assigned_to") @db.Uuid
  approvedBy      String?           @map("approved_by") @db.Uuid
  estimatedCost   Decimal?          @map("estimated_cost") @db.Decimal(12, 2)
  actualCost      Decimal?          @map("actual_cost") @db.Decimal(12, 2)
  startedAt       DateTime?         @map("started_at") @db.Timestamptz(6)
  completedAt     DateTime?         @map("completed_at") @db.Timestamptz(6)
  cancelledAt     DateTime?         @map("cancelled_at") @db.Timestamptz(6)
  cancellationReason String?        @map("cancellation_reason") @db.Text
  completionNotes    String?        @map("completion_notes") @db.Text
  createdAt       DateTime          @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt       DateTime          @updatedAt @db.Timestamptz(6) @map("updated_at")
  deletedAt       DateTime?         @db.Timestamptz(6) @map("deleted_at")

  asset           Asset?               @relation(fields: [assetId], references: [id], onDelete: Restrict)
  requester       User                 @relation("WorkOrderRequestedBy", fields: [requestedBy], references: [id], onDelete: Restrict)
  technician      User?                @relation("WorkOrderAssignedTo", fields: [assignedTo], references: [id], onDelete: Restrict)
  approver        User?                @relation("WorkOrderApprovedBy", fields: [approvedBy], references: [id], onDelete: Restrict)
  workOrderPriority WorkOrderPriority  @relation(fields: [workOrderPriorityId], references: [id], onDelete: Restrict)
  workOrderStatus   WorkOrderStatus    @relation(fields: [workOrderStatusId], references: [id], onDelete: Restrict)
